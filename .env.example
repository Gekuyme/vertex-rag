# General
APP_ENV=development
LOG_LEVEL=info
VERTEX_WEB_IMAGE=ghcr.io/vertex-rag/vertex-rag-web:latest
VERTEX_API_IMAGE=ghcr.io/vertex-rag/vertex-rag-api:latest
VERTEX_WORKER_IMAGE=ghcr.io/vertex-rag/vertex-rag-worker:latest

# API
API_PORT=8080
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
RATE_LIMIT_RPM=240
RATE_LIMIT_BURST=60

# Worker
WORKER_PORT=8082

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vertex_rag
POSTGRES_USER=vertex
POSTGRES_PASSWORD=vertex
DATABASE_URL=postgres://vertex:vertex@postgres:5432/vertex_rag?sslmode=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache
CACHE_ENABLED=true
CACHE_RETRIEVAL_TTL=10m
CACHE_ANSWER_TTL=10m
CACHE_UNSTRICT_ANSWER=false

# S3 / MinIO
S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_BUCKET=vertex-rag
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# AI providers
LLM_PROVIDER=ollama
EMBED_PROVIDER=gemini
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_OPENAI_STRICT=
LLM_MODEL_OPENAI_UNSTRICT=
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MODEL_GEMINI=gemini-2.5-flash-lite
LLM_MODEL_GEMINI_STRICT=
LLM_MODEL_GEMINI_UNSTRICT=
LLM_MODEL_OLLAMA=llama3.2
LLM_MODEL_OLLAMA_STRICT=
LLM_MODEL_OLLAMA_UNSTRICT=
LLM_OLLAMA_BASE_URL=
LLM_OLLAMA_BASE_URL_STRICT=
LLM_OLLAMA_BASE_URL_UNSTRICT=
LLM_OLLAMA_NUM_CTX=4096
LLM_OLLAMA_KEEP_ALIVE=30m
LLM_HTTP_TIMEOUT=60s
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF=400ms
LLM_MAX_CONTEXT_CHARS=7000
EMBED_MODEL_OPENAI=text-embedding-3-small
EMBED_MODEL_GEMINI=gemini-embedding-001
EMBED_MODEL_OLLAMA=nomic-embed-text
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://ollama:11434

# Unstrict web search
WEB_SEARCH_ENABLED=false
SEARCH_API_PROVIDER=brave
SEARCH_API_KEY=
SEARCH_MAX_RESULTS=5
SEARCH_HTTP_TIMEOUT=6s
RETRIEVAL_PIPELINE_VERSION=v2
QUERY_REWRITE_ENABLED=true
QUERY_EXPANSION_ENABLED=true
HYDE_ENABLED=false
SPARSE_SEARCH_PROVIDER=opensearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=vertex-document-chunks
SPARSE_SEARCH_TIMEOUT=4s
SPARSE_SEARCH_MAX_RESULTS=50
SPARSE_INDEX_ENABLED=true
RERANKER_ENABLED=true
RERANKER_URL=http://reranker:80
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT=8s
RERANKER_MAX_RESULTS=30
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe123!
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
UNSTRICT_LEGACY_TOGGLE_WEB_SEARCH=true

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

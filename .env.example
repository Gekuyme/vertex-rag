# General
APP_ENV=development
LOG_LEVEL=info

# API
API_PORT=8080
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
CORS_ORIGIN=http://localhost:3000

# Worker
WORKER_PORT=8082

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vertex_rag
POSTGRES_USER=vertex
POSTGRES_PASSWORD=vertex
DATABASE_URL=postgres://vertex:vertex@postgres:5432/vertex_rag?sslmode=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# S3 / MinIO
S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_BUCKET=vertex-rag
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# AI providers
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://ollama:11434

# Unstrict web search
WEB_SEARCH_ENABLED=false
SEARCH_API_PROVIDER=brave
SEARCH_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

